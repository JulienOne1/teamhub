{
  "buildCommand": "composer install --no-dev --optimize-autoloader && echo 'Build complete'",
  "installCommand": "echo 'No npm install needed'",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}